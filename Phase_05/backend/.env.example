# === Database Configuration ===
# For Local Development (with SSH Tunnel):
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_USER=[db-user]
POSTGRES_PASSWORD=[db-password]
POSTGRES_DB=postgres
SUPPORT_DB_SCHEMA=support
SUPPORT_DB_VERSION_TABLE=alembic_version_support

# For AWS RDS (Direct VPC Access):
# POSTGRES_SERVER=osomba-marketplace-db.cyxecuk22kgr.us-east-1.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_USER=[db-user]
# POSTGRES_PASSWORD=[db-password]
# POSTGRES_DB=postgres

# === AWS Configuration (REQUIRED for JWT Verification & S3) ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=osomba-marketplace-assets

# === Cognito Configuration ===
# Values can be found in `mobile/lib/amplify_outputs.dart` or AWS Console
COGNITO_USER_POOL_ID=us-east-1_vf5HVszbN
COGNITO_APP_CLIENT_ID=513m3vscibhska2jie3ganrcn9
COGNITO_ADMIN_GROUP_NAME=Admins
COGNITO_AGENT_GROUP_NAME=Agents

# === Payment Gateway Configuration ===
MPESA_API_KEY=

# === Support Deployment Configuration ===
SUPPORT_API_PREFIX=/support-api
SUPPORT_FRONTEND_URL=https://support.osomba.com
BACKEND_CORS_ORIGINS='["http://localhost:3000","https://support.osomba.com"]'
